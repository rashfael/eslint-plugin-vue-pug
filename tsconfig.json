{
  "compilerOptions": {
    "target": "esnext",
    "module": "preserve",
    "moduleResolution": "bundler",
    "lib": ["es2022"],
    "types": ["node", "vitest/globals"],
    "allowJs": false,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "noImplicitThis": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "eslint-plugin-vue/dist/*": ["./node_modules/eslint-plugin-vue/dist/*"]
    }
  },
  "include": ["lib/**/*"],
  "exclude": [
    "dist",
    "node_modules",
    "eslint-plugin-vue",
    "tests",
    "tools",
    "docs"
  ]
}
